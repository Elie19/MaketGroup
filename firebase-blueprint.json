{
  "entities": {
    "User": {
      "title": "User",
      "description": "Profil utilisateur de la plateforme",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID unique Firebase Auth" },
        "displayName": { "type": "string", "description": "Nom affiché" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "description": "URL de la photo de profil" },
        "phoneNumber": { "type": "string" },
        "location": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Annonce": {
      "title": "Annonce",
      "description": "Annonce de bien ou service",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "userId": { "type": "string", "description": "ID du vendeur" },
        "userName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "sold", "deleted"] }
      },
      "required": ["title", "description", "category", "price", "userId", "createdAt", "status"]
    },
    "Message": {
      "title": "Message",
      "description": "Message privé entre utilisateurs",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "annonceId": { "type": "string" }
      },
      "required": ["senderId", "receiverId", "content", "timestamp"]
    },
    "Group": {
      "title": "Group",
      "description": "Groupe de discussion",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "creatorId": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["public", "private"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "creatorId", "type", "createdAt"]
    },
    "GroupMessage": {
      "title": "GroupMessage",
      "description": "Message dans un groupe",
      "type": "object",
      "properties": {
        "groupId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["groupId", "senderId", "content", "timestamp"]
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "Collection des utilisateurs" },
    "annonces": { "schema": "Annonce", "description": "Collection des annonces" },
    "messages": { "schema": "Message", "description": "Messages privés" },
    "groups": { "schema": "Group", "description": "Groupes de discussion" },
    "group_messages": { "schema": "GroupMessage", "description": "Messages des groupes" }
  }
}
