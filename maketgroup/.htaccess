# .htaccess — MaketGroup root
Options -Indexes

# [FIX] Headers de securite HTTP
<IfModule mod_headers.c>
    # Empêche le clickjacking (chargement dans une iframe)
    Header always set X-Frame-Options "SAMEORIGIN"

    # Empêche le sniffing de type MIME
    Header always set X-Content-Type-Options "nosniff"

    # Active le filtre XSS du navigateur (legacy, complemente la CSP)
    Header always set X-XSS-Protection "1; mode=block"

    # Ne pas envoyer le Referer hors du site
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Content Security Policy : n'autoriser que les ressources du meme domaine
    # et Google Fonts (utilise dans header.php)
    Header always set Content-Security-Policy "\
        default-src 'self'; \
        script-src 'self'; \
        style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; \
        font-src 'self' https://fonts.gstatic.com; \
        img-src 'self' data:; \
        connect-src 'self'; \
        frame-ancestors 'none';"

    # HSTS : forcer HTTPS pour 1 an (a activer seulement si le domaine est en HTTPS)
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Bloquer l'acces aux fichiers de configuration sensibles
<FilesMatch "\.(env|sql|md|json|lock|gitignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>
